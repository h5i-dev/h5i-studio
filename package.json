{
  "name": "h5i-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "H5I Fleet Command — an orbital mission-control viewer for `h5i team`",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "serve": "node server/index.mjs",
    "start": "node server/index.mjs",
    "typecheck": "tsc -b --noEmit",
    "test": "node --test test/parse.test.mjs test/derive.test.mjs test/api.test.mjs",
    "test:e2e": "node --test test/e2e.test.mjs",
    "test:all": "node --test test/"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.20"
  }
}
